{
  "name": "epub-reader",
  "private": true,
  "version": "0.1.0",
  "description": "A highly customizable offline EPUB reader for Windows",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:monitor": "concurrently --names \"DEV,MON\" --prefix-colors \"blue,cyan\" \"npm run dev\" \"npm run monitor\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --pretty false",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "monitor": "node scripts/monitor.js"
  },
  "dependencies": {
    "dexie": "^4.0.10",
    "epubjs": "^0.3.93",
    "fflate": "^0.8.2",
    "framer-motion": "^11.15.0",
    "mammoth": "^1.11.0",
    "marked": "^17.0.3",
    "mobi": "^0.0.1",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^9.2.1",
    "electron": "^33.3.1",
    "esbuild": "^0.27.3",
    "jsdom": "^28.1.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.0"
  }
}
